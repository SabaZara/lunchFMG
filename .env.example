# ============================================================
#  LUNCH meal-access  —  configuration
#  Copy this file to ".env" and fill in real values.
#  NEVER commit the real .env (it is gitignored).
# ============================================================

# IANA timezone used to decide the "calendar day" for the once-per-day rule.
# Default is Tbilisi. (tzdata is bundled so this works on Windows too.)
TIMEZONE=Asia/Tbilisi

# First admin account, seeded on first run.
# The app REFUSES TO START if the password is blank or "changeme".
# Use a strong, unique password.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Secret used to sign the login session cookie.
# Must be a long random string and STAY THE SAME across restarts
# (otherwise everyone is logged out / sessions can be forged).
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Shared secret that proves a request came through the Cloudflare tunnel.
# start.bat generates this automatically; you normally do NOT edit it by hand.
# If empty, the remote-admin gate falls back to "block everything but the kiosk".
TUNNEL_SECRET=

# Network binding. Keep HOST at 127.0.0.1 so the cafeteria LAN cannot reach
# the app directly — only the kiosk PC itself and the Cloudflare tunnel can.
HOST=127.0.0.1
PORT=8000

# SQLite database file (single-file, easy to back up).
DB_PATH=lunch.db
